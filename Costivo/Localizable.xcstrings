{
  "sourceLanguage": "en",
  "strings": {
    "%.2f / %@": {
      "comment": "A label showing the cost of a specific labor rate, followed by the unit of measurement. The first argument is the price of the labor rate, formatted to two decimal places. The second argument is the unit of measurement for the labor rate.",
      "isCommentAutoGenerated": true,
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "new",
            "value": "%1$.2f / %2$@"
          }
        }
      }
    },
    "%@ / %@": {
      "comment": "A subheading displaying the price per unit of a material, formatted to two decimal places. The argument is the price of the material per unit. The argument is the string “%.2f”.",
      "isCommentAutoGenerated": true,
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "new",
            "value": "%1$@ / %2$@"
          }
        }
      }
    },
    "%@ %@%.2f": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "new",
            "value": "%1$@ %2$@%3$.2f"
          }
        }
      }
    },
    "%@%.2f": {
      "comment": "A label displaying the total cost of a job, formatted with the user's selected currency. The argument is the string “MKD”.",
      "isCommentAutoGenerated": true,
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "new",
            "value": "%1$@%2$.2f"
          }
        }
      }
    },
    "%@%.2f / %@": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "new",
            "value": "%1$@%2$.2f / %3$@"
          }
        }
      }
    },
    "•": {
      "comment": "A bullet point used in a list of suggested prices for predefined materials.",
      "isCommentAutoGenerated": true
    },
    "~%.2f": {
      "comment": "A price displayed in the checkout view, formatted to two decimal places. The value is the suggested price of a predefined material.",
      "isCommentAutoGenerated": true
    },
